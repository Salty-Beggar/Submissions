
#include <algorithm>
#include <iostream>
using namespace std;

const long int MAX_N = 100000;
const long int MAX_K = 360;

long int t, n, k;
int arr[MAX_N];
long int dp[MAX_N][MAX_K+1][4];
// 0: The value itself. 1: The index after the value where there's an increase. 2: The index the first increase is at. 3: The value of the item at that position.

void solve() {
    for (long int i = 0; i < n; i++) {
        dp[i][0][0] = 0;
        dp[i][0][1] = n;
        dp[i][0][2] = n;
        dp[i][0][3] = 0;
    }
    for (int j = 1; j <= k; j++) {
        for (long int i = 0; i < n; i++) {
            int curItem = arr[n-1-i];
            if (i == 0) {
                dp[0][k][0] = min(curItem, j);
                dp[0][k][1] = n;
                dp[0][k][2] = n-1-i;
                dp[0][k][3] = min(curItem, j);
            }else {
                long int prevKItem = dp[i][k-1];
                long int prevIValue = dp[i-1][k];
                long int addedValue = prevKItem[1] - i;
                if (prevKItem[0]+addedValue >= prevIValue[0]) {
                    dp[i][k][0] = dp[i][k-1][0]+addedValue;
                    dp[i][k][1] = (arr[prevKItem[1]] == prevKItem[3]+1)
                        ? arr[prevKItem[1]][k-1][1] 
                        : prevKItem[1];
                    dp[i][k][2] = n-1-i;
                    dp[i][k][3] = prevKItem[3]+1;
                }else {
                    dp[i][k][0] = prevIValue[0];
                    dp[i][k][1] = prevIValue[2];
                    dp[i][k][2] = prevIValue[2];
                    dp[i][k][3] = 0;
                }
            }
        }
    }
}

int main() {
    cin >> t;
    for (int i = 0; i < t; i++) {
        cin >> n >> k;
        for (long int j = 0; j < n; j++) {
            cin >> arr[j];
        }
        solve();
    }
    
    return 0;
}

